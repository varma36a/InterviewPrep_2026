{
  "ConnectionStrings": {
    "MongoDb": "mongodb://127.0.0.1:27017",
    "Redis": "redis:6379"
  },
  "Mongo": {
    "DatabaseName": "TaxComplianceDb"
  },
  "Authorization": {
    "Enabled": false
  },
  "Jwt": {
    "Key": "CHANGE_THIS_TO_A_LONG_SECURE_KEY_FOR_PRODUCTION",
    "Issuer": "TaxCompliancePlatform",
    "Audience": "TaxCompliancePlatform.Client",
    "AccessTokenExpiryMinutes": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
